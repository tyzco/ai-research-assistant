# ============================================================
# AI 学术文献精读助手 - 环境变量配置
# ============================================================
# cp .env.example .env 并填入你的 API Key
# ============================================================

# ---- DeepSeek API（必须）----
# 获取：https://platform.deepseek.com/api_keys
DEEPSEEK_API_KEY=sk-your-key-here
DEEPSEEK_BASE_URL=https://api.deepseek.com
DEEPSEEK_MODEL=deepseek-chat

# ---- 本地嵌入模型（默认，不需要 API Key）----
EMBEDDING_PROVIDER=local
LOCAL_EMBEDDING_MODEL=BAAI/bge-small-zh

# ---- Jina AI 嵌入（可选，设置 EMBEDDING_PROVIDER=jina 启用）----
JINA_API_KEY=

# ---- 视觉模型（可选，用于图表理解）----
# 推荐阿里云百炼 Qwen-VL-Max，每张图约 ¥0.01
# 获取：https://dashscope.aliyun.com/
VISION_MODEL=qwen-vl-max
VISION_API_KEY=
VISION_BASE_URL=https://dashscope.aliyuncs.com/compatible-mode/v1

# ---- Semantic Scholar（可选）----
# 获取：https://www.semanticscholar.org/product/api
SEMANTIC_SCHOLAR_API_KEY=

# ---- 调整参数（可选）----
MAX_SEARCH_RESULTS=50
CHUNK_SIZE=2048
RETRIEVAL_TOP_K=5
APIFY_API_KEY=
APIFY_API_KEY=
